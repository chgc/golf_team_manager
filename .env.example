# Copy this file to `.env` at the repository root for local development.
# Shell environment variables still override values from `.env`.

# Shared backend settings
HTTP_HOST=localhost
HTTP_PORT=8080
DB_PATH=data\golf_team_manager.sqlite
DB_AUTO_MIGRATE=true

# Replace placeholders locally. Do not commit real credentials.
LINE_CLIENT_ID=your-line-channel-id
LINE_CLIENT_SECRET=your-line-channel-secret
LINE_REDIRECT_URI=http://localhost:8080/api/auth/line/callback
FRONTEND_URL=http://localhost:4200
JWT_SECRET=replace-with-a-local-dev-secret
JWT_TTL=1h

# Frontend runtime auth mode is configured separately in frontend\public\app-config.js.
