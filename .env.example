# Reference only: the repo reads process environment variables and does not auto-load this file.
# Copy the values you need into your shell or deployment environment.

# Shared backend settings
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
DB_PATH=data\golf_team_manager.sqlite
DB_AUTO_MIGRATE=true

# Default local auth mode
AUTH_MODE=dev_stub
AUTH_DEV_DEFAULT_ROLE=manager
AUTH_DEV_DEFAULT_NAME=Demo Manager
AUTH_DEV_DEFAULT_SUBJECT=dev-manager
AUTH_DEV_DEFAULT_USER_ID=dev-user:dev-manager
AUTH_DEV_DEFAULT_PLAYER_ID=

# LINE mode backend settings
# Replace placeholders locally. Do not commit real credentials.
LINE_CLIENT_ID=your-line-channel-id
LINE_CLIENT_SECRET=your-line-channel-secret
LINE_REDIRECT_URI=http://127.0.0.1:8080/api/auth/line/callback
FRONTEND_URL=http://localhost:4200
JWT_SECRET=replace-with-a-local-dev-secret
JWT_TTL=1h

# Frontend runtime auth mode is configured separately in frontend\public\app-config.js.
